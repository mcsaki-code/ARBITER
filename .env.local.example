# Anthropic — required
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# Polymarket Live Trading — OPTIONAL (paper trading works without these)
# ============================================================
# To get your private key:
#   1. Log in to polymarket.com
#   2. Go to Settings → Advanced → Export Private Key
#   3. Copy the hex string (starts with 0x...)
#
# WARNING: This key controls your funds. Never share it or commit it.
# ============================================================

# Your Polymarket wallet private key (Polygon)
# POLYMARKET_PRIVATE_KEY=0x...

# Polygon RPC URL (Alchemy, Infura, or public)
# POLYGON_RPC_URL=https://polygon-rpc.com

# Set to "true" to enable live trading (requires passing guardrails first)
# LIVE_TRADING_ENABLED=false
